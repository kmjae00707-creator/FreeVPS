local function refreshBlockList()
    -- Clear both columns
    for _, child in ipairs(activeScroll:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    for _, child in ipairs(mutedScroll:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end

    for _, name in ipairs(seenModels) do
        local muted = blockedNames[name] == true

        if muted then
            -- Muted column: click to unmute
            local row = makeModelRow(mutedScroll, name, true)
            row.MouseButton1Click:Connect(function()
                blockedNames[name] = false
                refreshBlockList()
                scheduleSaveConfig()
            end)
        else
            -- Active column: click to mute
            local row = makeModelRow(activeScroll, name, false)
            row.MouseButton1Click:Connect(function()
                blockedNames[name] = true
                refreshBlockList()
                scheduleSaveConfig()
            end)
        end
    end

    activeScroll.CanvasSize = UDim2.new(0, 0, 0, activeLayout.AbsoluteContentSize.Y + 10)
    mutedScroll.CanvasSize  = UDim2.new(0, 0, 0, mutedLayout.AbsoluteContentSize.Y + 10)
end

local function trackModelName(name)
    for _, v in ipairs(seenModels) do
        if v == name then return end
    end
    table.insert(seenModels, name)
    refreshBlockList()
    scheduleSaveConfig()
end

