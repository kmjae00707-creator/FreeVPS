local function applyLoadedConfig(cfg)
    if type(cfg) ~= "table" then return end

    local aim = cfg.aimbot
    if type(aim) == "table" then
        if type(aim.isSystemOn) == "boolean"       then isSystemOn       = aim.isSystemOn end
        if type(aim.projectileSpeed) == "number"    then projectileSpeed  = aim.projectileSpeed end
        if type(aim.chargingDelay) == "number"       then chargingDelay    = aim.chargingDelay end
        if type(aim.mouseSensitivity) == "number"    then mouseSensitivity = aim.mouseSensitivity end
        if type(aim.leadMultiplier) == "number"      then leadMultiplier   = aim.leadMultiplier end
        if type(aim.extraFrontOffset) == "number"    then extraFrontOffset = aim.extraFrontOffset end
        if type(aim.myVelocityWeight) == "number"    then myVelocityWeight = aim.myVelocityWeight end
    end

    local toggles = cfg.toggles
    if type(toggles) == "table" then
        if type(toggles.isAutoTargetOn) == "boolean" then isAutoTargetOn = toggles.isAutoTargetOn end
        if type(toggles.isAutoMoveOn) == "boolean"   then isAutoMoveOn   = toggles.isAutoMoveOn end
        if type(toggles.isAutoItemOn) == "boolean"   then isAutoItemOn   = toggles.isAutoItemOn end
        if type(toggles.isAutoTwoOn) == "boolean"    then isAutoTwoOn    = toggles.isAutoTwoOn end
        if type(toggles.isTouchBlockOn) == "boolean" then isTouchBlockOn = toggles.isTouchBlockOn end
        if type(toggles.isWatchOn) == "boolean"      then isWatchOn      = toggles.isWatchOn end
    end

    if cfg.blockedNames ~= nil then
        for k in pairs(blockedNames) do blockedNames[k] = nil end
        for _, name in ipairs(copyStringList(cfg.blockedNames)) do
            blockedNames[name] = true
        end
    end

    if cfg.seenModels ~= nil then
        seenModels = copyStringList(cfg.seenModels)
    end

    if type(cfg.selectedTargetName) == "string" and cfg.selectedTargetName ~= "" then
        pendingSelectedName = cfg.selectedTargetName
    end

    if cfg.Setrairty ~= nil then
        local n = tonumber(cfg.Setrairty)
        if n then setrairtyValue = n end
    end

    if type(cfg.serverLink) == "string" then
        serverLinkValue = cfg.serverLink
    end

    local gui = cfg.gui
    if type(gui) == "table" then
        if type(gui.x) == "number" then pendingGui.x = gui.x end
        if type(gui.y) == "number" then pendingGui.y = gui.y end
        if gui.tab == "main" or gui.tab == "misc" then pendingGui.tab = gui.tab end
    end
end

local function loadConfigFromFile()
    local defaults = getDefaultConfig()
    local store      = readConfigStore()
    local accountCfg = store[accountKey]

    applyLoadedConfig(defaults)
    if type(accountCfg) == "table" then
        applyLoadedConfig(accountCfg)
    end
    return accountCfg or defaults
end

loadConfigFromFile()

