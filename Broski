-- ==========================================
local function startWatch()
    local ef = Workspace:WaitForChild("Entities", 10)
    if not ef then return end
    -- Seed existing models silently
    for _, child in ipairs(ef:GetChildren()) do
        if child:IsA("Model") then trackModelName(child.Name) end
    end
    watchConn = ef.ChildAdded:Connect(function(child)
        if not child:IsA("Model") then return end
        trackModelName(child.Name)
        if isWatchOn then sendDiscord(child.Name) end
    end)
end

local function stopWatch()
    if watchConn then watchConn:Disconnect() ; watchConn = nil end
end

