    if not pg then return end
    local consumables = pg:FindFirstChild("GuisNoReset")
        and pg.GuisNoReset:FindFirstChild("InventoryFrame")
        and pg.GuisNoReset.InventoryFrame:FindFirstChild("Consumables")
    if not consumables then return end

    pcall(function()
        local ev = consumables:FindFirstChild("Determination")
        if ev and ev:FindFirstChild("Frame") and ev.Frame:FindFirstChild("EQUIP") then
            ev.Frame.EQUIP.RemoteEvent:FireServer(localPlayer)
        end
    end)
    if not isAutoItemOn then return end
    task.wait(6)

    pcall(function()
        local ev = consumables:FindFirstChild("Dice Of Fate")
        if ev and ev:FindFirstChild("Frame") and ev.Frame:FindFirstChild("EQUIP") then
            ev.Frame.EQUIP.RemoteEvent:FireServer(localPlayer)
        end
    end)
    if not isAutoItemOn then return end
