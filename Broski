local function canUseConfigIO()
    return type(writefile) == "function"
        and type(readfile) == "function"
        and type(isfile) == "function"
        and type(isfolder) == "function"
        and type(makefolder) == "function"
end

local function ensureConfigDir()
    if not canUseConfigIO() then return false end
    local dir = CONFIG_PATH:match("(.+)/[^/]+$")
    if dir and not isfolder(dir) then
        pcall(makefolder, dir)
    end
    return true
end

local function isLegacySingleConfig(data)
    return type(data) == "table" and type(data.aimbot) == "table"
end

local function readConfigStore()
    if not canUseConfigIO() or not isfile(CONFIG_PATH) then
        return {}
    end
    local ok, raw = pcall(readfile, CONFIG_PATH)
    if not ok or type(raw) ~= "string" or raw == "" then
        return {}
    end
    local decodeOk, data = pcall(function()
        return HttpService:JSONDecode(raw)
    end)
    if not decodeOk or type(data) ~= "table" then
        return {}
    end
    -- 예전 단일 config → 현재 계정 키로 자동 변환
    if isLegacySingleConfig(data) then
        local store = { [accountKey] = data }
        pcall(function()
            ensureConfigDir()
            writefile(CONFIG_PATH, HttpService:JSONEncode(store))
        end)
        return store
    end
    return data
end

local function writeConfigStore(store)
    if not canUseConfigIO() then return end
    if not ensureConfigDir() then return end
    local ok, json = pcall(function()
        return HttpService:JSONEncode(store)
    end)
    if ok and json then
        pcall(writefile, CONFIG_PATH, json)
    end
end

local function copyStringList(src)
    local out = {}
    if type(src) == "table" then
        for i, v in ipairs(src) do
            if type(v) == "string" then out[i] = v end
        end
    end
    return out
end

