-- ==========================================
-- [ AUTO TARGET SEARCH ]
-- ==========================================
local function findNextAutomaticTarget()
    local myCharacter = localPlayer.Character
    if not myCharacter or not myCharacter:FindFirstChild("HumanoidRootPart") then return nil end
    local myPos = myCharacter.HumanoidRootPart.Position
    local ef    = Workspace:FindFirstChild("Entities")
    if not ef then return nil end
    local closest, shortest = nil, math.huge
    for _, model in ipairs(ef:GetChildren()) do
        if model:IsA("Model") and model:FindFirstChild("HumanoidRootPart") then
            local d = (model.HumanoidRootPart.Position - myPos).Magnitude
            if d < shortest then shortest = d ; closest = model end
        end
    end
    return closest
end

-- ==========================================
-- [ RENDERSTEP MAIN LOOP ]
-- ==========================================
RunService.RenderStepped:Connect(function()
    if _G.KoreanChatActive == true then
        indicator.Transparency = 1
        safeMouseRelease()
        return
    end

    local myCharacter = localPlayer.Character
    local humanoid    = myCharacter and myCharacter:FindFirstChildOfClass("Humanoid")
    local myRoot      = myCharacter and myCharacter:FindFirstChild("HumanoidRootPart")

    -- Auto movement
    if isAutoMoveOn and humanoid and myRoot and isSystemOn then
        local target     = selectedModelInstance
        local targetRoot = target and target:FindFirstChild("HumanoidRootPart")

        if targetRoot then
            local dist = (targetRoot.Position - myRoot.Position).Magnitude
            if dist > APPROACH_DIST then isApproaching = true end

            if isApproaching then
                if dist <= STOP_DIST then
                    isApproaching  = false
                    lastMoveChange = 0
                else
                    local dir = (targetRoot.Position - myRoot.Position) * Vector3.new(1, 0, 1)
                    if dir.Magnitude > 0 then humanoid:Move(dir.Unit, false) end
                    if math.random(1, 100) <= 40 then humanoid.Jump = true end
                end
            else
                if tick() - lastMoveChange >= moveChangeInterval then
                    lastMoveChange     = tick()
                    moveChangeInterval = math.random(5, 15) / 10
                    local rx = math.random(-1, 1)
                    local rz = math.random(-1, 1)
                    if rx == 0 and rz == 0 then rx = 1 end
                    currentMoveDir = Vector3.new(rx, 0, rz)
                    if math.random(1, 100) <= 40 then humanoid.Jump = true end
                end
                if currentMoveDir.Magnitude > 0 then
                    humanoid:Move(currentMoveDir, true)
                end
            end
        else
            isApproaching = false
            humanoid:Move(Vector3.new(0, 0, 0), false)
        end
    end

    if not isSystemOn then
        indicator.Transparency = 1
        safeMouseRelease()
        return
    end

    -- Auto targeting
    if isAutoTargetOn then
        local valid = selectedModelInstance
            and selectedModelInstance.Parent
            and selectedModelInstance:FindFirstChild("HumanoidRootPart")
        if not valid then
            local next = findNextAutomaticTarget()
            if next ~= selectedModelInstance then
                safeMouseRelease()
                selectedModelInstance = next
                refreshEntityList()
            end
        end
    end

    if not myRoot then
        indicator.Transparency = 1
        safeMouseRelease()
        return
    end

    -- Auto equip weapon
    local currentTool = myCharacter:FindFirstChildOfClass("Tool")
    if not currentTool and not isEquipping and not isSkillCasting then
        isEquipping = true
        task.spawn(function()
            safeMouseRelease()
            VIM:SendKeyEvent(true,  Enum.KeyCode.One, false, game)
            task.wait(0.05)
            VIM:SendKeyEvent(false, Enum.KeyCode.One, false, game)
            task.wait(0.5)
            isEquipping = false
        end)
    end

    -- Predictive aim & fire
    local targetModel = selectedModelInstance
    if targetModel and targetModel.Parent and targetModel:FindFirstChild("HumanoidRootPart") then
        local targetRoot     = targetModel.HumanoidRootPart
        local targetPos      = targetRoot.Position
        local targetVelocity = targetRoot.AssemblyLinearVelocity or Vector3.new(0, 0, 0)
        local myPos          = myRoot.Position
        local myVelocity     = myRoot.AssemblyLinearVelocity or Vector3.new(0, 0, 0)

        local predictedPos = calculateRelativeLeadPosition(
            targetPos, targetVelocity, myPos, myVelocity, projectileSpeed)
        indicator.Position     = predictedPos
        indicator.Transparency = 0

        local sx, sy, onScreen = worldToScreen(predictedPos)
        if onScreen then
            aimScreenX = sx
            aimScreenY = sy
            syncMouseToAim()
        end

        local targetCFrame = CFrame.new(camera.CFrame.Position, predictedPos)
        if isWindowFocused or IS_TOUCH then
            camera.CFrame = camera.CFrame:Lerp(targetCFrame, mouseSensitivity)
        else
            -- Alt-Tab 중: 마우스 위치가 (0,0)으로 고정되므로 카메라 즉시 조준
            camera.CFrame = targetCFrame
        end

        if not isSkillCasting and onScreen and not IS_TOUCH then
            if not isCharging then
                safeMousePress()
            elseif tick() - lastShotTime >= chargingDelay then
                safeMouseRelease()
            end
        elseif not isSkillCasting then
            safeMouseRelease()
        end
    else
        if not isSkillCasting then safeMouseRelease() end
        indicator.Transparency = 1
        selectedModelInstance  = nil
    end
end)
