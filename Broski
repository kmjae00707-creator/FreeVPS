    isWatchOn = not isWatchOn
    setBtnState(nBtn, nLbl, nDot, nStroke,
        isWatchOn, "Entity Watch: ON ", "Entity Watch: OFF")
    if isWatchOn then startWatch() else stopWatch() end
    scheduleSaveConfig()
end)

-- Sync muted list from server every 30 s
task.spawn(function()
    while true do
        task.wait(30)
        pcall(function()
            local res = request({
                Url    = SERVER_URL .. "/muted-list",
                Method = "GET",
            })
            if not (res and res.Body) then return end
            local data = HttpService:JSONDecode(res.Body)
            if not (data and data.muted) then return end
            local changed = false
            for _, nm in ipairs(data.muted) do
                if not blockedNames[nm] then
                    blockedNames[nm] = true
                    changed = true
                end
            end
            if changed then
                refreshBlockList()
                scheduleSaveConfig()
            end
        end)
    end
end)

