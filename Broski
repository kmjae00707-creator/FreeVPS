local function executeTwoSkill()
    isSkillCasting = true
    safeMouseRelease()

    VIM:SendKeyEvent(true, Enum.KeyCode.Two, false, game)
    task.wait(0.05)
    VIM:SendKeyEvent(false, Enum.KeyCode.Two, false, game)
    task.wait(0.5)

    for _ = 1, 5 do
        if not isAutoTwoOn then break end
        syncMouseToAim()
        local x = aimScreenX or 0
        local y = aimScreenY or 0
        VIM:SendMouseButtonEvent(x, y, 0, true, game, 0)
        task.wait(0.05)
        VIM:SendMouseButtonEvent(x, y, 0, false, game, 0)
        task.wait(0.15)
    end

    VIM:SendKeyEvent(true, Enum.KeyCode.One, false, game)
    task.wait(0.05)
    VIM:SendKeyEvent(false, Enum.KeyCode.One, false, game)
    task.wait(0.5)

    isSkillCasting = false
end

local function startAutoTwoLoop()
    task.spawn(function()
        while isAutoTwoOn do
