local configSaveQueued = false

local function resolveTargetByName(name)
    if not name then return nil end
    local ef = Workspace:FindFirstChild("Entities")
    if not ef then return nil end
    for _, model in ipairs(ef:GetChildren()) do
        if model:IsA("Model") and model.Name == name and model:FindFirstChild("HumanoidRootPart") then
            return model
        end
    end
    return nil
end

local function buildConfigTable()
    local muted = {}
    for name, enabled in pairs(blockedNames) do
        if enabled then table.insert(muted, name) end
    end
    table.sort(muted)

    local tab = miscScroll.Visible and "misc" or "main"
    local pos = mainFrame.Position

    return {
        version = CONFIG_VERSION,
        aimbot = {
            isSystemOn       = isSystemOn,
            projectileSpeed  = projectileSpeed,
            chargingDelay    = chargingDelay,
            mouseSensitivity = mouseSensitivity,
            leadMultiplier   = leadMultiplier,
            extraFrontOffset = extraFrontOffset,
            myVelocityWeight = myVelocityWeight,
        },
        toggles = {
            isAutoTargetOn = isAutoTargetOn,
            isAutoMoveOn   = isAutoMoveOn,
            isAutoItemOn   = isAutoItemOn,
            isAutoTwoOn    = isAutoTwoOn,
            isTouchBlockOn = isTouchBlockOn,
            isWatchOn      = isWatchOn,
        },
        selectedTargetName = selectedModelInstance and selectedModelInstance.Name or nil,
        blockedNames       = muted,
        seenModels         = copyStringList(seenModels),
        Setrairty          = setrairtyValue,
        serverLink         = serverLinkValue,
        gui = {
            x   = pos.X.Offset,
            y   = pos.Y.Offset,
            tab = tab,
        },
    }
end

local function saveConfigNow()
    if not canUseConfigIO() then return end
    local store = readConfigStore()
    store[accountKey] = buildConfigTable()
    writeConfigStore(store)
end

scheduleSaveConfig = function()
