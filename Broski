local function worldToScreen(worldPos)
    local vp, visible = camera:WorldToViewportPoint(worldPos)
    if visible and vp.Z > 0 then
        return vp.X, vp.Y, true
    end
    return nil, nil, false
end

local function syncMouseToAim()
    if not aimScreenX or not aimScreenY then return end
    pcall(function()
        VIM:SendMouseMoveEvent(aimScreenX, aimScreenY, game)
    end)
end

local function safeMousePress()
    if not isCharging then
        isCharging   = true
        lastShotTime = tick()
        syncMouseToAim()
        local x = aimScreenX or 0
        local y = aimScreenY or 0
        VIM:SendMouseButtonEvent(x, y, 0, true, game, 0)
    end
end

local function safeMouseRelease()
    if isCharging then
        isCharging = false
        syncMouseToAim()
        local x = aimScreenX or 0
        local y = aimScreenY or 0
        VIM:SendMouseButtonEvent(x, y, 0, false, game, 0)
    end
end

local function calculateRelativeLeadPosition(targetPos, targetVelocity, myPos, myVelocity, bulletSpeed)
    local distance        = (targetPos - myPos).Magnitude
    local totalTime       = (distance / bulletSpeed) + chargingDelay
    local blendedVelocity = targetVelocity - (myVelocity * myVelocityWeight)
    local moveDirection   = blendedVelocity.Magnitude > 0.1
        and blendedVelocity.Unit or Vector3.new(0, 0, 0)
    local leadVector      = (blendedVelocity * totalTime * leadMultiplier)
        + (moveDirection * extraFrontOffset)
    return targetPos + leadVector
end

-- ==========================================
-- [ TOUCH BLOCK MAX ]
-- ==========================================
local TOUCH_COLLISION_GROUP = "Crazy22Ghost"
pcall(function()
    PhysicsService:RegisterCollisionGroup(TOUCH_COLLISION_GROUP)
end)

local touchCharConns      = {}
local touchPartConns      = {}
local touchDisabledConns  = {}
local touchDisabledSet    = {}
local touchSavedProps     = {}
local touchLoopConns      = {}
local touchFireHooked     = false
local touchOrigFireTouch  = nil
local touchNamecallHooked = false
local touchOrigNamecall   = nil

local TOUCH_ROOT_PARTS = {
    HumanoidRootPart = true,
    LowerTorso       = true,
}

local function wipeTable(t)
    for k in pairs(t) do t[k] = nil end
end

local function deferFn(fn)
    if task and task.defer then task.defer(fn) else spawn(fn) end
end

local function isTouchMyPart(part)
    if not part or not localPlayer.Character then return false end
    return part:IsDescendantOf(localPlayer.Character)
end

local function isTouchRootPart(part)
    return TOUCH_ROOT_PARTS[part.Name] == true
end

local function clearTouchList(conns)
    for _, conn in ipairs(conns) do
        pcall(function() conn:Disconnect() end)
    end
    wipeTable(conns)
end

local function rememberTouchPart(part)
    if not touchSavedProps[part] then
        touchSavedProps[part] = {
            CanTouch       = part.CanTouch,
            CanCollide     = part.CanCollide,
            CanQuery       = part.CanQuery,
            CollisionGroup = part.CollisionGroup,
        }
    end
end

local function muteTouchConn(conn)
    if touchDisabledSet[conn] then return end
    touchDisabledSet[conn] = true
    pcall(function() conn:Disable() end)
    table.insert(touchDisabledConns, conn)
end

local function restoreTouchSignals()
    for _, conn in ipairs(touchDisabledConns) do
        pcall(function() conn:Enable() end)
    end
    wipeTable(touchDisabledConns)
    wipeTable(touchDisabledSet)
end

local function installTouchFireHook()
    if touchFireHooked or not firetouchinterest or not hookfunction then return end
    local ok = pcall(function()
        touchOrigFireTouch = hookfunction(firetouchinterest, function(part0, part1, toggle)
            if isTouchBlockOn and (isTouchMyPart(part0) or isTouchMyPart(part1)) then return end
            return touchOrigFireTouch(part0, part1, toggle)
        end)
    end)
    if ok then touchFireHooked = true end
end

local function installTouchNamecallHook()
    if touchNamecallHooked or not hookmetamethod or not getnamecallmethod then return end
    local ok = pcall(function()
        touchOrigNamecall = hookmetamethod(game, "__namecall", function(self, ...)
            local method = getnamecallmethod()
            if isTouchBlockOn and method == "FireTouchInterest" then
                local args = { ... }
                if isTouchMyPart(args[1]) or isTouchMyPart(args[2]) then return end
            end
            return touchOrigNamecall(self, ...)
        end)
    end)
    if ok then touchNamecallHooked = true end
end

local TOUCH_CHILD_CLASSES = { TouchInterest = true, TouchTransmitter = true }

local function removeTouchInternals(part)
    for _, child in ipairs(part:GetChildren()) do
        if TOUCH_CHILD_CLASSES[child.ClassName] then
            pcall(function() child:Destroy() end)
        end
    end
end

local function mutePartTouchSignals(part)
    if not getconnections then return end
    pcall(function()
        for _, conn in ipairs(getconnections(part.Touched)) do muteTouchConn(conn) end
    end)
    pcall(function()
        for _, conn in ipairs(getconnections(part.TouchEnded)) do muteTouchConn(conn) end
    end)
end

local function silenceExternalTouching(char)
    if not getconnections then return end
    local checked = {}
    for _, obj in ipairs(char:GetDescendants()) do
        if obj:IsA("BasePart") then
            local touching = {}
            pcall(function() touching = obj:GetTouchingParts() end)
            for _, other in ipairs(touching) do
                if not isTouchMyPart(other) and not checked[other] then
                    checked[other] = true
                    mutePartTouchSignals(other)
                end
            end
        end
    end
end

local function clearTouchPartConns()
    for _, conns in pairs(touchPartConns) do
        for _, conn in ipairs(conns) do pcall(function() conn:Disconnect() end) end
    end
    wipeTable(touchPartConns)
end

local function bindTouchPartAntiReset(part)
    if touchPartConns[part] then return end
    touchPartConns[part] = {}
    local function guard(prop, desired)
        table.insert(touchPartConns[part], part:GetPropertyChangedSignal(prop):Connect(function()
            if not isTouchBlockOn then return end
            if part[prop] ~= desired then pcall(function() part[prop] = desired end) end
        end))
    end
    guard("CanTouch", false)
    if not isTouchRootPart(part) then guard("CanCollide", false) end
    guard("CanQuery", false)
end

local function hardenTouchPart(part)
    if not part:IsA("BasePart") then return end
    rememberTouchPart(part)
    pcall(function() part.CanTouch = false end)
    pcall(function() part.CanQuery = false end)
    pcall(function() part.CollisionGroup = TOUCH_COLLISION_GROUP end)
    if isTouchRootPart(part) then
        pcall(function() part.CanCollide = true end)
    else
        pcall(function() part.CanCollide = false end)
        pcall(function() part.Massless = true end)
    end
    removeTouchInternals(part)
    mutePartTouchSignals(part)
    bindTouchPartAntiReset(part)
end

local function softenTouchPart(part)
    if not part:IsA("BasePart") then return end
    local saved = touchSavedProps[part]
    if saved then
        pcall(function() part.CanTouch       = saved.CanTouch end)
        pcall(function() part.CanCollide     = saved.CanCollide end)
        pcall(function() part.CanQuery       = saved.CanQuery end)
        pcall(function() part.CollisionGroup = saved.CollisionGroup end)
    else
        pcall(function() part.CanTouch = true end)
        pcall(function() part.CanCollide = true end)
        pcall(function() part.CanQuery = true end)
    end
    pcall(function() part.Massless = false end)
end

local function applyTouchToCharacter(char, enabled)
    if not char then return end
    for _, obj in ipairs(char:GetDescendants()) do
        if obj:IsA("BasePart") then
            if enabled then hardenTouchPart(obj) else softenTouchPart(obj) end
        end
    end
end

local function enforceTouchCharacter(char)
    for _, obj in ipairs(char:GetDescendants()) do
        if obj:IsA("BasePart") then
            if obj.CanTouch then pcall(function() obj.CanTouch = false end) end
            if obj.CanQuery then pcall(function() obj.CanQuery = false end) end
            if not isTouchRootPart(obj) and obj.CanCollide then
                pcall(function() obj.CanCollide = false end)
            end
            if obj.CollisionGroup ~= TOUCH_COLLISION_GROUP then
                pcall(function() obj.CollisionGroup = TOUCH_COLLISION_GROUP end)
            end
            removeTouchInternals(obj)
        end
    end
end

local function clearTouchCharConns()
    clearTouchList(touchCharConns)
    clearTouchPartConns()
    restoreTouchSignals()
end

local function bindTouchCharacter(char)
    clearTouchCharConns()
    if not char then return end
    applyTouchToCharacter(char, isTouchBlockOn)
    table.insert(touchCharConns, char.DescendantAdded:Connect(function(obj)
        if not isTouchBlockOn or not obj:IsA("BasePart") then return end
        deferFn(function()
            if isTouchBlockOn and obj.Parent then hardenTouchPart(obj) end
        end)
    end))
    table.insert(touchCharConns, char.AncestryChanged:Connect(function(_, parent)
        if not parent then clearTouchCharConns() end
    end))
end

local function startTouchLoops()
    clearTouchList(touchLoopConns)
    table.insert(touchLoopConns, RunService.Heartbeat:Connect(function()
        if not isTouchBlockOn then return end
        local char = localPlayer.Character
        if char then enforceTouchCharacter(char) end
    end))
    table.insert(touchLoopConns, RunService.PostSimulation:Connect(function()
        if not isTouchBlockOn then return end
        local char = localPlayer.Character
        if char then silenceExternalTouching(char) end
    end))
end

local function stopTouchLoops()
    clearTouchList(touchLoopConns)
end

local function setTouchBlock(enabled)
    isTouchBlockOn = enabled
    pcall(installTouchFireHook)
    pcall(installTouchNamecallHook)
    local char = localPlayer.Character
    if enabled then
        if char then
            applyTouchToCharacter(char, true)
            bindTouchCharacter(char)
        end
        startTouchLoops()
    else
        clearTouchCharConns()
        stopTouchLoops()
        if char then
            applyTouchToCharacter(char, false)
            bindTouchCharacter(char)
        end
    end
end

