local function refreshEntityList()
    for _, child in ipairs(scrollFrame:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end

    local entitiesFolder = Workspace:FindFirstChild("Entities")
    if not entitiesFolder then
        scrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
        return
    end

    local nameCounts = {}
    for _, model in ipairs(entitiesFolder:GetChildren()) do
        if model:IsA("Model") then
            local baseName = model.Name
            nameCounts[baseName] = (nameCounts[baseName] or 0) + 1
            local displayName = nameCounts[baseName] > 1
                and (baseName .. "  [" .. nameCounts[baseName] .. "]") or baseName
            local isSelected = (selectedModelInstance == model)

            local btn = Instance.new("TextButton")
            btn.Size             = UDim2.new(1, 0, 0, ROW_H)
            btn.BackgroundColor3 = isSelected and Color3.fromRGB(80, 18, 18) or Color3.fromRGB(20, 20, 28)
            btn.Text             = ""
            btn.AutoButtonColor  = false
            btn.BorderSizePixel  = 0
            btn.Parent           = scrollFrame
            do
                local c = Instance.new("UICorner")
                c.CornerRadius = UDim.new(0, 5)
                c.Parent       = btn
                local s = Instance.new("UIStroke")
                s.Color     = isSelected and Color3.fromRGB(180, 40, 40) or Color3.fromRGB(35, 35, 48)
                s.Thickness = 1
                s.Parent    = btn
            end

            local sideBar = Instance.new("Frame")
            sideBar.Size             = UDim2.new(0, 2, 0, 16)
            sideBar.Position         = UDim2.new(0, 0, 0.5, -8)
            sideBar.BackgroundColor3 = isSelected and C.ACCENT or C.DIM
            sideBar.BorderSizePixel  = 0
            sideBar.Parent           = btn
            do
                local c = Instance.new("UICorner")
                c.CornerRadius = UDim.new(0, 1)
                c.Parent       = sideBar
            end

            local lbl = Instance.new("TextLabel")
            lbl.Size                 = UDim2.new(1, -14, 1, 0)
            lbl.Position             = UDim2.new(0, 10, 0, 0)
            lbl.BackgroundTransparency = 1
            lbl.Text                 = displayName
            lbl.TextColor3           = isSelected and C.WHITE or C.DIM
            lbl.TextSize             = 12
            lbl.Font                 = isSelected and Enum.Font.SourceSansBold or Enum.Font.SourceSans
            lbl.TextXAlignment       = Enum.TextXAlignment.Left
            lbl.TextTruncate         = Enum.TextTruncate.AtEnd
            lbl.Parent               = btn

            btn.MouseButton1Click:Connect(function()
                if isAutoTargetOn then
                    isAutoTargetOn = false
                    setBtnState(autoTargetBtn, autoTargetLbl, autoTargetDot, autoTargetStroke,
                        false, "Auto Target:       ON ", "Auto Target:       OFF")
                end
                if selectedModelInstance == model then
                    safeMouseRelease() ; selectedModelInstance = nil
                else
                    safeMouseRelease() ; selectedModelInstance = model
                end
                refreshEntityList()
                scheduleSaveConfig()
            end)
        end
    end
    scrollFrame.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 10)
end

